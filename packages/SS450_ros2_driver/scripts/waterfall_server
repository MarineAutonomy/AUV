#!/usr/bin/env python3
"""Serve the sidescan waterfall web UI on a local HTTP port."""

import argparse
import http.server
import os
import socketserver
import sys

from ament_index_python.packages import get_package_share_directory


def main():
    parser = argparse.ArgumentParser(description='Sidescan waterfall web server')
    parser.add_argument('--port', type=int, default=9001, help='HTTP port (default: 9001)')
    args = parser.parse_args()

    web_dir = os.path.join(get_package_share_directory('sidescan_ros2'), 'web')
    if not os.path.isdir(web_dir):
        print(f'Web directory not found: {web_dir}', file=sys.stderr)
        sys.exit(1)

    handler = lambda *h_args, **h_kwargs: http.server.SimpleHTTPRequestHandler(
        *h_args, directory=web_dir, **h_kwargs)

    class ReusableTCPServer(socketserver.TCPServer):
        allow_reuse_address = True

    with ReusableTCPServer(('', args.port), handler) as httpd:
        print(f'Serving waterfall UI from {web_dir} on http://0.0.0.0:{args.port}/')
        try:
            httpd.serve_forever()
        except KeyboardInterrupt:
            pass


if __name__ == '__main__':
    main()
